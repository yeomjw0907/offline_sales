# Kakao OAuth (카카오 개발자 콘솔에서 발급)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# NextAuth (openssl rand -base64 32 으로 생성)
AUTH_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ixgfxlyqqquywrbohwpe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml4Z2Z4bHlxcXF1eXdyYm9od3BlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNzcyNzksImV4cCI6MjA5MTY1MzI3OX0.zUjzxGVRhPKBjKXY4KzHQbDG5irnJAhrdTVK75UDtiA

# Supabase Service Role (Supabase 대시보드 > Settings > API > service_role)
# ⚠️ 절대 NEXT_PUBLIC_ 붙이지 말 것
SUPABASE_SERVICE_ROLE_KEY=

# App URL (개발: http://localhost:3000 / 운영: https://[vercel도메인])
NEXTAUTH_URL=http://localhost:3000

# 관리자 이메일/비밀번호 (코드에 저장되지 않음 — 반드시 환경 변수로만 설정)
# Supabase public.users 에 동일 이메일 행이 있어야 하고 role 은 admin 또는 super_admin 이어야 로그인됨.
# 여러 명: ADMIN_LOGIN_ACCOUNTS 만 사용 (쉼표/줄바꿈/세미콜론으로 구분). 각 항목 형식은 email:password (비밀번호에 콜론 넣지 말 것)
# ADMIN_LOGIN_ACCOUNTS=admin1@x.com:비번1,admin2@x.com:비번2
# 또는 단일 계정 레거시:
# ADMIN_LOGIN_EMAIL=admin@x.com
# ADMIN_LOGIN_PASSWORD=
ADMIN_LOGIN_ACCOUNTS=
ADMIN_LOGIN_EMAIL=
ADMIN_LOGIN_PASSWORD=

# 영업자료 파일 업로드 버킷(없으면 자동 생성 시도, 기본값: partner-materials)
MATERIALS_STORAGE_BUCKET=partner-materials
